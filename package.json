{
  "name": "warborn-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n WEB,BRIDGE -c cyan,magenta \"next dev\" \"npm:bridge\"",
    "dev:web": "next dev",
    "bridge": "npm --prefix services/game-bridge start",
    "bridge:check": "npm --prefix services/game-bridge run check",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
