SESSION_SECRET=gere-uma-chave-segura-com-openssl-rand-base64-32

# Website data (accounts profile, news and forum). Provision Neon through Vercel.
DATABASE_URL=

# Local development only. Production never writes SQLite unless explicitly enabled.
WARBORN_USE_SQLITE=false

# Future HTTPS bridge running beside Microsoft SQL Server 2014.
GAME_BRIDGE_URL=
GAME_BRIDGE_SHARED_SECRET=

# Account ID that receives the initial website administrator role when using the bridge.
INITIAL_ADMIN_ACCOUNT_ID=
